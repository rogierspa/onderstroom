# ── Supabase ──────────────────────────────────────
# Haal deze op via: supabase.com → jouw project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...

# ── Anthropic ─────────────────────────────────────
# Haal op via: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Web Push (VAPID keys) ─────────────────────────
# Genereer eenmalig via terminal: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BAa...
VAPID_PRIVATE_KEY=xxx...
VAPID_MAILTO=jouw@email.nl
